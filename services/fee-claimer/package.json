{
  "name": "world-fee-claimer",
  "version": "0.1.0",
  "private": true,
  "description": "Automated pump.fun creator-fee claimer for the WORLD flagship country coins (USA, CHN, RUS). Claims fees every 10 minutes and forwards to the $WORLD dev wallet.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx watch src/index.ts",
    "once": "tsx src/index.ts --once",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.4",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
