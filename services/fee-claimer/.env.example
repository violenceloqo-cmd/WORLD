# =======================================================================
# WORLD fee-claimer — environment configuration
# Copy to .env, fill in real values, NEVER commit .env to git.
# =======================================================================

# ---- Solana RPC (paid endpoint strongly recommended) ------------------
# Helius works great. You already have a key in the main app; reuse it
# or generate a separate one for this service.
# Example: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=

# ---- Destination ------------------------------------------------------
# Public address of the $WORLD dev wallet. All claimed fees land here.
WORLD_DEV_WALLET=

# ---- Country coin dev wallets (the wallets that CREATED each coin) ----
# Base58-encoded secret keys (the format Phantom exports).
# These three wallets must be the creators on pump.fun for their mints.
DEV_USA_PRIVATE_KEY=
DEV_CHN_PRIVATE_KEY=
DEV_RUS_PRIVATE_KEY=

# ---- Country coin mints ----------------------------------------------
MINT_USA=
MINT_CHN=
MINT_RUS=

# ---- Behavior ---------------------------------------------------------
# Cron schedule. Default: every 10 minutes.
CRON_SCHEDULE=*/10 * * * *

# Skip claim if pending fees below this many lamports (1 SOL = 1e9 lamports).
# 0.01 SOL = 10_000_000. Below this the priority + tx fees eat the claim.
MIN_CLAIM_LAMPORTS=10000000

# Lamports to leave in each dev wallet for the next claim's tx fees.
# 0.003 SOL = 3_000_000. Do not set below ~2_000_000.
RESERVE_LAMPORTS=3000000

# Priority fee in microlamports per compute unit. 100_000 is a sane floor.
PRIORITY_MICRO_LAMPORTS=100000

# Compute unit limit for the claim transaction. pump.fun default is 200_000.
COMPUTE_UNITS=200000

# DRY_RUN=true logs intended actions but never signs / sends. Start here.
DRY_RUN=true

# PAUSED=true makes every cron tick a no-op. Flip without redeploying.
PAUSED=false

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# ---- Telegram notifications ------------------------------------------
# Create a bot with @BotFather, then get the chat id by messaging the bot
# and visiting https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Send a Telegram message on every successful run (including "below threshold").
# Set to false to only get alerted on errors and actual transfers.
TELEGRAM_VERBOSE=true
